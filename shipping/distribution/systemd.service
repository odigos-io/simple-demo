[Unit]
Description=Odigos Demo Shipping Quote Service
After=network.target

[Service]
ExecStart=/usr/bin/odigos-demo-shipping
KillMode=mixed
Restart=on-failure
RestartSec=1
RestartSteps=1s
RestartMaxDelaySec=1min
Type=simple
User=odigos
Group=odigos
Environment="PORT=8087"

[Install]
WantedBy=multi-user.target
